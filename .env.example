# Copy this file to .env and adjust the values for your setup.
# Values set here override the defaults in docker-compose.yml.

# IP address of your Synology NAS (used for web links in the UI)
SYNOLOGY_IP=192.168.1.216

# Name of the SMB share that maps to /mnt/nas on the host
SMB_SHARE_NAME=documents

# Ollama host – use 172.17.0.1 on Linux Docker, host.docker.internal on Docker Desktop
OLLAMA_HOST=172.17.0.1
OLLAMA_PORT=11434

# Models
EMBED_MODEL=nomic-embed-text
LLM_MODEL=llama3.2:3b

# Indexer settings
SCAN_INTERVAL=3600
INDEXER_THREADS=2
CHUNK_SIZE=600
CHUNK_OVERLAP=80
OCR_LANG=deu+eng

# Qdrant
QDRANT_COLLECTION=documents
